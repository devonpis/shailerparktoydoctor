# Copy to `.env` for local publishing scripts (never commit `.env`).
# See: docs/meta-local-api-setup.md — app sptoydoctor App ID: 1311610070937761

# Optional: when a project has >10 images, publish-social picks the best 10 via vision (auto mode)
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_API_BASE=https://api.openai.com/v1

# Live site root for --use-site (Instagram/Threads image_url after git push)
# SITE_BASE_URL=https://sptoydoctor.com.au

# Graph API version path segment (graph.facebook.com/{version}/...)
META_GRAPH_API_VERSION=v25.0

# Meta app (developers.facebook.com → Your app → Settings → Basic)
META_APP_ID=
META_APP_SECRET=

# Long-lived User access token, OR Page access token — see guide for which you need
META_ACCESS_TOKEN=

# Facebook Page ID (numeric) — for Page posts and Instagram discovery
META_PAGE_ID=

# Optional: Page access token (if omitted, script fetches from me/accounts using META_ACCESS_TOKEN)
# META_PAGE_ACCESS_TOKEN=

# Instagram Business/Creator account id (often starts with 1784…) — from Graph API
META_INSTAGRAM_USER_ID=

# Threads API (graph.threads.net) — not interchangeable with META_ACCESS_TOKEN
# App ID is usually the same as META_APP_ID (sptoydoctor: 1311610070937761)
META_THREADS_APP_ID=
META_THREADS_APP_SECRET=
META_THREADS_ACCESS_TOKEN=
META_THREADS_USER_ID=
