<!DOCTYPE html>
<!-- Copy to projects/<folder>/index.html when status is DONE. See docs/website-go-live.md -->
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <title><!-- projectName --> — Shailer Park Toy Doctor</title>
    <meta name="description" content="<!-- shortened description, ~160 chars -->" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href="https://sptoydoctor.com.au/projects/<!-- URL-encoded folder -->/" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lobster&family=Nunito:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/new/css/site.css" />
  </head>
  <body data-active-page="projects" data-project-folder="<!-- folder name -->">
    <div id="site-header"></div>

    <main class="page-main">
      <p class="project-back">
        <a href="/new/projects/">← All projects</a>
      </p>

      <!-- Hero: first of hero.*, after.*, before.*, WIP-001.* -->
      <div class="project-hero">
        <img
          src="/projects/<!-- folder encoded -->/hero-or-after.jpg"
          alt="<!-- projectName -->"
        />
      </div>

      <h1><!-- title (slogan) --></h1>
      <h3 class="project-subtitle"><!-- projectName --></h3>
      <div class="project-tag-row">
        <div id="project-skills-root"></div>
        <ul class="project-tags">
          <!-- <li class="project-tag">tag</li> -->
        </ul>
      </div>

      <p class="project-meta"><!-- endDate AU, e.g. 6 May 2026 --></p>
      <p class="project-lead text-lead"><!-- description (short summary) --></p>

      <!-- If googleReview is set in config.json: blockquote under summary -->

      <!-- Before/after: omit if none; skip image already used as hero -->
      <!-- WIP grid: WIP-001, WIP-002, … -->
      <!--
      <section class="project-section">
        <h2 class="jw-heading-100">Work in progress</h2>
        <div class="project-wip-grid">…</div>
      </section>
      -->

      <!-- YouTube iframes if youtubeUrl / youtubeShortUrl -->
      <!--
      <section class="project-section">
        <h2 class="jw-heading-100">Videos</h2>
        <div class="project-videos">
          <div class="project-video">
            <div class="project-video__embed"><iframe …></iframe></div>
          </div>
          <div class="project-video">
            <div class="project-video__embed"><iframe …></iframe></div>
          </div>
        </div>
      </section>
      -->

      <section class="project-prose">
        <h2 class="jw-heading-100">The repair</h2>
        <!-- One <p> per paragraph from repairDetails (blank line between paragraphs in config). -->
        <p><!-- repairDetails paragraph 1 --></p>
        <p><!-- repairDetails paragraph 2 --></p>
        <h2 class="jw-heading-100">About this item</h2>
        <!-- One <p> per paragraph from itemDetails. -->
        <p><!-- itemDetails paragraph 1 --></p>
        <p><!-- itemDetails paragraph 2 --></p>
      </section>

      <div class="projects-cta">
        <a class="cta-button" href="/new/contact.html">Send photos for a quote</a>
      </div>
    </main>

    <div id="site-footer"></div>

    <script src="/new/js/brand-text.js" defer></script>
    <script src="/new/js/site-chrome.js" defer></script>
    <script src="/new/js/skills.js" defer></script>
    <script src="/new/js/project-page-skills.js" defer></script>
  </body>
</html>
